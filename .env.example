# =========================================================================
# CareBridge Environment Variables Example
# Copy this file to client/.env and server/.env respectively and fill values
# =========================================================================

# --- SERVER ENVIRONMENT VARIABLES (server/.env) ---
PORT=3000
NODE_ENV=development

# Google Gemini API Key (powers both Wingman messages & NLP Smart Search)
GOOGLE_API_KEY=your_google_api_key_here

# Firebase Service Account (JSON stringified). E.g. {"type": "service_account", ...}
FIREBASE_SERVICE_ACCOUNT=your_stringified_firebase_service_account_json_here

# Unsplash Access Key (for professional portrait images)
UNSPLASH_ACCESS_KEY=your_unsplash_access_key_here


# --- CLIENT ENVIRONMENT VARIABLES (client/.env) ---
# Vite variables MUST start with VITE_ to be exposed to client React code
VITE_API_URL=http://localhost:3000

# Firebase Web SDK Configuration
VITE_FIREBASE_API_KEY=your_firebase_web_api_key_here
VITE_FIREBASE_AUTH_DOMAIN=your_firebase_project_domain_here
VITE_FIREBASE_PROJECT_ID=your_firebase_project_id_here
VITE_FIREBASE_STORAGE_BUCKET=your_firebase_storage_bucket_here
VITE_FIREBASE_MESSAGING_SENDER_ID=your_firebase_sender_id_here
VITE_FIREBASE_APP_ID=your_firebase_app_id_here

# Unsplash Access Key for Professional Images
VITE_UNSPLASH_ACCESS_KEY=your_unsplash_access_key_here
