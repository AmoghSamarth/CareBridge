# Client-side configuration (Vite requires VITE_ prefix to expose variables to browser)
VITE_API_URL=http://localhost:3000

# Landing site URL (port 5174 locally). On Vercel, set to https://care-bridge-coral.vercel.app
VITE_LANDING_URL=http://localhost:5174

# Firebase Web SDK Configuration
VITE_FIREBASE_API_KEY=your_firebase_web_api_key_here
VITE_FIREBASE_AUTH_DOMAIN=your_firebase_project_domain_here
VITE_FIREBASE_PROJECT_ID=your_firebase_project_id_here
VITE_FIREBASE_STORAGE_BUCKET=your_firebase_storage_bucket_here
VITE_FIREBASE_MESSAGING_SENDER_ID=your_firebase_sender_id_here
VITE_FIREBASE_APP_ID=your_firebase_app_id_here

# Unsplash Access Key for Professional Images
VITE_UNSPLASH_ACCESS_KEY=your_unsplash_access_key_here
